rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ──────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Conversations ──────────────────────────────────────────────────────
    match /conversations/{convId} {
      function isParticipant() {
        return request.auth != null &&
               request.auth.uid in resource.data.participants;
      }

      allow read: if isParticipant();

      // Any participant can update conversation metadata
      // (lastMessage, unreadCount, pinnedMessages, etc.)
      allow update: if isParticipant();

      // Only authenticated users can create conversations
      allow create: if request.auth != null &&
                       request.auth.uid in request.resource.data.participants;

      // ── Messages ──────────────────────────────────────────────────────────
      match /messages/{msgId} {
        function isSender() {
          return request.auth != null &&
                 request.auth.uid == resource.data.senderId;
        }

        function isConvParticipant() {
          return request.auth != null &&
                 request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        }

        // Any participant can read messages
        allow read: if isConvParticipant();

        // Any participant can create messages
        allow create: if isConvParticipant() &&
                         request.auth.uid == request.resource.data.senderId;

        // Edit (text + edited flag) and delete — sender only
        allow update: if isConvParticipant() && (
          // Sender can edit text or soft-delete
          isSender() ||
          // Any participant can update only the reactions field
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])
          )
        );

        allow delete: if false; // soft-delete only via update
      }
    }
  }
}
